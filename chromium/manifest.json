{
  "manifest_version": 3,
  "name": "Strava.cz Dynamic Food Previewer",
  "version": "1.0",
  "description": "Scrapes food text from Strava.cz and dynamically grabs the top web image search result.",
  "permissions": [],
  "host_permissions": [
    "https://duckduckgo.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://app.strava.cz/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
